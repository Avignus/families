generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  steamId      String   @unique
  personaName  String
  avatarUrl    String
  avatarMedium String   @default("")
  avatarFull   String   @default("")
  profileUrl   String?
  pixKey             String?  @unique
  email              String?  @unique
  emailPending       String?
  emailVerifyToken   String?  @unique
  emailVerifyExpiry  DateTime?
  reputationScore        Int      @default(0)
  creditsCents           Int      @default(0)
  chiefSpotEarningsCents Int      @default(0)
  isPremium              Boolean  @default(false)
  createdAt        DateTime @default(now())

  memberships        FamilyMembership[]
  wishlistItems      WishlistItem[]
  pledges            Pledge[]
  notifications      Notification[]
  chiefOf            Family[]             @relation("ChiefFamilies")
  votesOpened        Vote[]
  ballots            VoteBallot[]
  walletTransactions WalletTransaction[]
  gameRecommendations GameRecommendation[]
  userAchievements   UserAchievement[]
  userCosmetics      UserCosmetic[]
  equippedCosmetics  EquippedCosmetics?
  familyPersonalizations FamilyMemberPersonalization[]
}

model Family {
  id            String   @id @default(cuid())
  name          String
  currency      String   @default("BRL")
  chiefId       String
  chief         User     @relation("ChiefFamilies", fields: [chiefId], references: [id])
  createdAt     DateTime @default(now())

  isPublic      Boolean  @default(false)
  description   String?
  maxMembers    Int?
  entryFeeCents Int      @default(0)
  coverImageUrl String?
  inviteToken   String?  @unique

  // Spot marketplace
  spotPricingEnabled Boolean @default(false)
  spotFraction       Float   @default(0.20)  // 0.0–1.0; chief's share of net value
  spotMinPriceCents  Int     @default(0)     // floor price regardless of formula

  familyScore   Int     @default(0)
  autoApprove   Boolean @default(false)

  activeCoverThemeId   String?
  activeCoverTheme     Cosmetic? @relation("FamilyActiveCoverTheme", fields: [activeCoverThemeId], references: [id])
  activeCoverOverlayId String?
  activeCoverOverlay   Cosmetic? @relation("FamilyActiveCoverOverlay", fields: [activeCoverOverlayId], references: [id])
  activeCoverVideoId   String?
  activeCoverVideo     Cosmetic? @relation("FamilyActiveCoverVideo", fields: [activeCoverVideoId], references: [id])

  memberships            FamilyMembership[]
  wishlistItems          WishlistItem[]
  votes                  Vote[]
  gameRecommendations    GameRecommendation[]
  memberPersonalizations FamilyMemberPersonalization[]

  @@index([isPublic])
}

model FamilyMembership {
  id       String           @id @default(cuid())
  userId   String
  familyId String
  status   MembershipStatus @default(pending)
  joinedAt DateTime         @default(now())

  // Entry fee payment tracking (used when family.entryFeeCents > 0)
  mpPaymentId       String?  @unique
  mpStatus          String?
  mpQrCode          String?
  mpQrCodeBase64    String?
  mpTicketUrl       String?
  feePaidAt         DateTime?
  feeChargedCents   Int?     // total charged (entry fee + service fee)
  feeRefundedAt     DateTime?

  // Spot marketplace lease duration
  spotExpiresAt DateTime? // 1 year from activation; null = not a spot lease

  // Auto-distribution
  monthlyBudgetCents    Int       @default(0)
  autoDistributeEnabled Boolean   @default(false)
  lastAutoDistributedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  family Family @relation(fields: [familyId], references: [id])

  @@unique([userId, familyId])
  @@index([familyId, status])
  @@index([spotExpiresAt])
}

model WishlistItem {
  id               String         @id @default(cuid())
  familyId         String
  ownerUserId      String?
  steamAppId       Int
  targetPriceCents Int
  currency         String
  status           WishlistStatus @default(open)
  createdAt        DateTime       @default(now())
  disbursedAt          DateTime?
  disbursementMpId     String?
  pixKeyReminderLevel  Int       @default(0)

  family  Family  @relation(fields: [familyId], references: [id])
  owner   User?   @relation(fields: [ownerUserId], references: [id])
  pledges Pledge[]

  @@unique([familyId, steamAppId])
  @@index([familyId, status])
}

model Pledge {
  id             String        @id @default(cuid())
  wishlistItemId String
  pledgerUserId  String
  amountCents    Int
  status         PledgeStatus  @default(active)
  createdAt      DateTime      @default(now())

  creditsCentsUsed Int           @default(0)

  // Payment tracking
  mpPaymentId    String?       @unique
  mpAmountCents  Int?          // actual PIX charged amount (pixPortion + service fee)
  mpStatus       String?       // pending, approved, rejected, cancelled
  mpQrCode       String?       // PIX QR code (copy & paste)
  mpQrCodeBase64 String?       // QR code image
  mpTicketUrl    String?       // payment link
  paidAt         DateTime?

  wishlistItem WishlistItem @relation(fields: [wishlistItemId], references: [id])
  pledger      User         @relation(fields: [pledgerUserId], references: [id])

  @@index([wishlistItemId, status])
  @@index([pledgerUserId])
  @@index([mpPaymentId])
}

model Vote {
  id             String     @id @default(cuid())
  familyId       String
  steamAppId     Int
  openedByUserId String
  opensAt        DateTime   @default(now())
  closesAt       DateTime
  status         VoteStatus @default(open)
  createdAt      DateTime   @default(now())

  family     Family       @relation(fields: [familyId], references: [id])
  openedBy   User         @relation(fields: [openedByUserId], references: [id])
  ballots    VoteBallot[]
}

model VoteBallot {
  id       String     @id @default(cuid())
  voteId   String
  userId   String
  choice   VoteChoice
  castAt   DateTime   @default(now())

  vote Vote @relation(fields: [voteId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([voteId, userId])
}

model Notification {
  id              String           @id @default(cuid())
  recipientUserId String
  type            NotificationType
  payload         Json
  readAt          DateTime?
  createdAt       DateTime         @default(now())

  recipient User @relation(fields: [recipientUserId], references: [id])

  @@index([recipientUserId, readAt])
  @@index([recipientUserId, createdAt])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  amountCents Int
  type        String   // "credit" | "debit"
  reason      String   // "pledge_payment" | "pledge_withdrawn" | "item_cancelled"
  pledgeId    String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model GameRecommendation {
  id          String   @id @default(cuid())
  userId      String?
  familyId    String?
  type        String   // "individual" | "family"
  source      String   @default("cron") // "cron" | "ondemand"
  batchId     String?  // groups all records from the same on-demand request
  steamAppId  Int
  gameName    String
  reason      String
  rank        Int
  generatedAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family? @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt])
  @@index([familyId, generatedAt])
  @@index([userId, source, generatedAt])
}

model SteamPriceHistory {
  id         String   @id @default(cuid())
  steamAppId Int
  priceCents Int
  currency   String
  recordedAt DateTime @default(now())

  @@index([steamAppId, recordedAt])
}

model PlatformRevenue {
  id          String   @id @default(cuid())
  amountCents Int
  reason      String   // "surplus_fee" | future reasons
  metadata    Json?    // contextual data (itemId, gameName, etc.)
  createdAt   DateTime @default(now())

  @@index([reason, createdAt])
}

model SteamAppCache {
  steamAppId Int      @id
  payload    Json
  fetchedAt  DateTime @default(now())

  @@index([fetchedAt])
}

model SteamAppCatalog {
  appId     Int      @id
  name      String
  updatedAt DateTime @default(now())

  @@index([name])
}

model SteamUserCache {
  userId    String
  type      String   // "library" | "wishlist"
  payload   Json
  fetchedAt DateTime @default(now())

  @@id([userId, type])
  @@index([fetchedAt])
}

enum MembershipStatus {
  pending
  active
  rejected
  removed
}

enum WishlistStatus {
  open
  funded
  purchased
  cancelled
}

enum PledgeStatus {
  active
  withdrawn
  settled
}

enum VoteStatus {
  open
  closed
  cancelled
}

enum VoteChoice {
  yes
  no
  abstain
}

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  category    String
  rarity      String   // comum | incomum | raro | lendario
  setSlug     String?
  sortOrder   Int      @default(0)
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

model Cosmetic {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  type        String   // avatar_frame | profile_bg | name_tag | card_effect | cover_theme
  rarity      String
  config      Json
  isDefault   Boolean  @default(false)

  userCosmetics          UserCosmetic[]
  equippedAvatarFrame    EquippedCosmetics[]         @relation("EquippedAvatarFrame")
  equippedProfileBg      EquippedCosmetics[]         @relation("EquippedProfileBg")
  equippedNameTag        EquippedCosmetics[]         @relation("EquippedNameTag")
  equippedCardEffect     EquippedCosmetics[]         @relation("EquippedCardEffect")
  activeFamilyCover      Family[]                    @relation("FamilyActiveCoverTheme")
  activeFamilyOverlay    Family[]                    @relation("FamilyActiveCoverOverlay")
  activeFamilyVideo      Family[]                    @relation("FamilyActiveCoverVideo")
  personalCover          FamilyMemberPersonalization[] @relation("PersonalCoverTheme")
  personalOverlay        FamilyMemberPersonalization[] @relation("PersonalCoverOverlay")
  personalVideo          FamilyMemberPersonalization[] @relation("PersonalCoverVideo")
}

model UserCosmetic {
  id          String   @id @default(cuid())
  userId      String
  cosmeticId  String
  source      String   // achievement slug that granted this
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic    Cosmetic @relation(fields: [cosmeticId], references: [id])
  @@unique([userId, cosmeticId])
  @@index([userId])
}

model EquippedCosmetics {
  userId        String    @id
  avatarFrameId String?
  profileBgId   String?
  nameTagId     String?
  cardEffectId  String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarFrame   Cosmetic? @relation("EquippedAvatarFrame", fields: [avatarFrameId], references: [id])
  profileBg     Cosmetic? @relation("EquippedProfileBg", fields: [profileBgId], references: [id])
  nameTag       Cosmetic? @relation("EquippedNameTag", fields: [nameTagId], references: [id])
  cardEffect    Cosmetic? @relation("EquippedCardEffect", fields: [cardEffectId], references: [id])
}

model FamilyMemberPersonalization {
  userId         String
  familyId       String
  coverThemeId   String?
  coverOverlayId String?
  coverVideoId   String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  family         Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  coverTheme     Cosmetic? @relation("PersonalCoverTheme", fields: [coverThemeId], references: [id])
  coverOverlay   Cosmetic? @relation("PersonalCoverOverlay", fields: [coverOverlayId], references: [id])
  coverVideo     Cosmetic? @relation("PersonalCoverVideo", fields: [coverVideoId], references: [id])
  @@id([userId, familyId])
}

enum NotificationType {
  JOIN_REQUEST
  JOIN_APPROVED
  JOIN_REJECTED
  JOIN_FEE_PAID
  PLEDGE_RECEIVED
  PLEDGE_WITHDRAWN
  ITEM_FUNDED
  ITEM_PURCHASED
  VOTE_OPENED
  VOTE_CLOSED
  DISBURSEMENT_SENT
  PIX_KEY_REQUIRED
  OPPORTUNITY
  AUTO_PLEDGED
  PRICE_DROPPED
  PRICE_INCREASED
  ITEM_GONE_FREE
  PRICE_ALERT_LOW
  PRICE_ALERT_HIGH
  PIX_KEY_REMINDER
  PIX_KEY_FINAL_WARNING
  ENTRY_FEE_HELD
  PLEDGE_REFUNDED_NO_PIX_KEY
  ITEM_UNFUNDED_NO_PIX_KEY
  FAMILY_DELETED
  PLEDGE_REFUNDED_FAMILY_DELETED
  CREDITS_ADDED
  MEMBER_BOUGHT_GAME
  JOIN_PAYMENT_AWAITING_APPROVAL
  SPOT_EXPIRING_SOON
  SPOT_EXPIRED
  ACHIEVEMENT_UNLOCKED
}
