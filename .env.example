# PostgreSQL
DATABASE_URL="postgresql://families:families_secret@localhost:5432/families"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Steam
# Get from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY="your-steam-api-key-here"

# App
APP_BASE_URL="http://localhost:3000"
DEFAULT_CURRENCY="BRL"
DEFAULT_COUNTRY="BR"

# MercadoPago (recebimento de pagamentos)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN="your-mp-access-token"
# Opcional — secret para validar assinatura dos webhooks
MERCADOPAGO_WEBHOOK_SECRET="your-mp-webhook-secret"

# ── Pagamentos ───────────────────────────────────────────────────────────────
# Provider ativo: "asaas" (padrão) ou "efi"
PAYMENT_PROVIDER="asaas"

# Asaas (provider padrão — obtenha em https://www.asaas.com/api/index)
ASAAS_API_KEY="$aas_your-api-key-here"
ASAAS_DEFAULT_CUSTOMER_ID="cus_your-platform-customer-id"
ASAAS_WEBHOOK_SECRET="gere-um-secret-aleatorio"
ASAAS_TRANSFER_AUTH_SECRET="gere-um-secret-aleatorio"

# Efí Bank (provider alternativo — obtenha em https://dev.efipay.com.br)
# EFI_CLIENT_ID="seu-client-id"
# EFI_CLIENT_SECRET="seu-client-secret"
# EFI_CERT_B64="base64 -w0 certificado.p12"   # arquivo .p12 em base64
# EFI_CERT_PASSPHRASE=""                        # senha do .p12, ou vazio
# EFI_PIX_KEY="sua-chave-pix"                  # CPF, CNPJ, email ou chave aleatória
# EFI_WEBHOOK_SECRET="openssl rand -hex 32"
# EFI_SANDBOX="1"                               # remova em produção

# Resend (notificações por email)
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY="re_your-api-key-here"
RESEND_FROM="Families <noreply@families.app>"

# Discord Bot (autenticação interna do bot)
# Mesmo valor de BOT_API_SECRET no families-bot
BOT_API_SECRET="gere-um-secret-aleatorio-aqui"

# Google AI (recomendações de jogos com Gemini Flash)
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY="your-google-ai-api-key-here"
# Limite diário de buscas on-demand por usuário (padrão: 3; use um número alto em dev)
# RECOMMENDATION_DAILY_LIMIT=99

# Upstash Redis — rate limiting (obtenha em console.upstash.com → Redis → REST API)
UPSTASH_REDIS_REST_URL="https://your-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# Sentry — monitoramento de erros (obtenha em sentry.io → Settings → Projects → DSN)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@oyyy.ingest.sentry.io/zzz"
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="your-project-slug"
SENTRY_AUTH_TOKEN="sntrys_xxx"  # Settings → Auth Tokens → Create New Token
