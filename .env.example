# PostgreSQL
DATABASE_URL="postgresql://families:families_secret@localhost:5432/families"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Steam
# Get from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY="your-steam-api-key-here"

# App
APP_BASE_URL="http://localhost:3000"
DEFAULT_CURRENCY="BRL"
DEFAULT_COUNTRY="BR"

# MercadoPago
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN="your-mp-access-token"
# Opcional — secret para validar assinatura dos webhooks
MERCADOPAGO_WEBHOOK_SECRET="your-mp-webhook-secret"
